+                             .collect(Collectors.toList());
+
+            Collections.reverse(filtered);
+            if (lambdaIndex < filtered.size()) {
+                return Collections.singletonList(filtered.get(lambdaIndex));
+            } else {
+                return filtered;
+            }
+        }
